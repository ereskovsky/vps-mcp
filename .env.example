# Master password for the encrypted server vault (AES-256-GCM)
# Choose a strong, random passphrase and keep it safe — losing it means losing vault access.
VAULT_PASSWORD=change-me-to-a-strong-random-passphrase

# Bearer token for HTTP mode — clients must send: Authorization: Bearer <API_KEY>
API_KEY=change-me-to-a-random-api-key

# HTTP port (default: 3001)
# PORT=3001
