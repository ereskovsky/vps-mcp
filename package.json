{
  "name": "vps-mcp",
  "version": "1.0.0",
  "description": "MCP server for managing VPS servers via SSH",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js"
  },
  "dependencies": {
